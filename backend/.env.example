# Example backend environment variables
# Replace placeholders with your real values before deploying

# Neon (Postgres) connection URL (from Neon dashboard)
# Example: postgresql://<user>:<pass>@<host>:5432/<db>?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_mdwVgytf0MX4@ep-frosty-cake-atzxvmiy-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Upstash Redis REST credentials (from Upstash console)
# UPSTASH_REDIS_REST_URL looks like: https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN is the REST token value
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server settings
PORT=3000
NODE_ENV=production
